# EmailJS — copy this file to .env.local and replace the placeholders.
# https://www.emailjs.com  ·  Restart `npm run dev` after editing.

# Required for submission features (forms, import, dataset wizard)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_TEMPLATE_ID=your_default_template_id

# Optional: override the default template for specific flows
# VITE_EMAILJS_TEMPLATE_ID_FORM=
# VITE_EMAILJS_TEMPLATE_ID_IMPORT=
# VITE_EMAILJS_TEMPLATE_ID_DATASET=
# VITE_EMAILJS_TEMPLATE_ID_FLEXIBLE=
